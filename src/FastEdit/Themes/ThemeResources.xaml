<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:FastEdit.Infrastructure.Converters"
                    xmlns:search="clr-namespace:ICSharpCode.AvalonEdit.Search;assembly=ICSharpCode.AvalonEdit">

    <!-- Converters -->
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
    <converters:FileOpenModeToDisplayConverter x:Key="FileOpenModeToDisplayConverter"/>
    <converters:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
    <converters:EqualityConverter x:Key="EqualityConverter"/>
    <converters:StringToBrushConverter x:Key="StringToBrushConverter"/>
    <converters:FileNameToIconConverter x:Key="FileNameToIconConverter"/>

    <!-- Default Dark Theme Colors (will be overwritten at runtime by ThemeService) -->

    <!-- Window -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1e1e1e"/>
    <SolidColorBrush x:Key="WindowForegroundBrush" Color="#d4d4d4"/>
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#3c3c3c"/>
    <SolidColorBrush x:Key="TitleBarForegroundBrush" Color="#cccccc"/>

    <!-- Editor -->
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#1e1e1e"/>
    <SolidColorBrush x:Key="EditorForegroundBrush" Color="#d4d4d4"/>
    <SolidColorBrush x:Key="EditorLineNumbersForegroundBrush" Color="#858585"/>
    <SolidColorBrush x:Key="EditorCurrentLineBackgroundBrush" Color="#282828"/>
    <SolidColorBrush x:Key="EditorSelectionBackgroundBrush" Color="#264f78"/>
    <SolidColorBrush x:Key="EditorSelectionForegroundBrush" Color="#ffffff"/>
    <SolidColorBrush x:Key="EditorFindHighlightBrush" Color="#78ffc800"/>

    <!-- Hex Editor -->
    <SolidColorBrush x:Key="HexOffsetForegroundBrush" Color="#569cd6"/>
    <SolidColorBrush x:Key="HexBytesForegroundBrush" Color="#d4d4d4"/>
    <SolidColorBrush x:Key="HexAsciiForegroundBrush" Color="#b5cea8"/>
    <SolidColorBrush x:Key="HexModifiedBackgroundBrush" Color="#6b4c00"/>
    <SolidColorBrush x:Key="HexNullByteForegroundBrush" Color="#4d4d4d"/>
    <SolidColorBrush x:Key="HexSelectedForegroundBrush" Color="#ffffff"/>

    <!-- Panels -->
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#252526"/>
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#3c3c3c"/>
    <SolidColorBrush x:Key="TreeViewBackgroundBrush" Color="#252526"/>
    <SolidColorBrush x:Key="TreeViewItemHoverBrush" Color="#2a2d2e"/>
    <SolidColorBrush x:Key="TreeViewItemSelectedBrush" Color="#04395e"/>

    <!-- Tabs -->
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="#2d2d2d"/>
    <SolidColorBrush x:Key="TabActiveBackgroundBrush" Color="#1e1e1e"/>
    <SolidColorBrush x:Key="TabForegroundBrush" Color="#969696"/>
    <SolidColorBrush x:Key="TabActiveForegroundBrush" Color="#ffffff"/>
    <SolidColorBrush x:Key="TabBorderBrush" Color="#252526"/>

    <!-- Status Bar -->
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#007acc"/>
    <SolidColorBrush x:Key="StatusBarForegroundBrush" Color="#ffffff"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#3c3c3c"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#d4d4d4"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#505050"/>

    <!-- Scrollbars -->
    <SolidColorBrush x:Key="ScrollBarBackgroundBrush" Color="#1e1e1e"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#424242"/>

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentBrush" Color="#007acc"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#f48771"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#cca700"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#89d185"/>

    <!-- Menu colors -->
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#252526"/>
    <SolidColorBrush x:Key="MenuForegroundBrush" Color="#d4d4d4"/>
    <SolidColorBrush x:Key="MenuHoverBackgroundBrush" Color="#2a2d2e"/>
    <SolidColorBrush x:Key="MenuBorderBrush" Color="#3c3c3c"/>

    <ControlTemplate x:Key="FastEditTopLevelHeaderMenuItemTemplate" TargetType="{x:Type MenuItem}">
        <Grid>
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter ContentSource="Header"
                                  RecognizesAccessKey="True"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
            </Border>
            <Popup x:Name="PART_Popup"
                   AllowsTransparency="True"
                   Focusable="False"
                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                   Placement="Bottom"
                   PopupAnimation="Fade">
                <Border Background="{DynamicResource MenuBackgroundBrush}"
                        BorderBrush="{DynamicResource MenuBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="4"
                        SnapsToDevicePixels="True">
                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                    KeyboardNavigation.TabNavigation="Cycle"/>
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource MenuHoverBackgroundBrush}"/>
            </Trigger>
            <Trigger Property="IsSubmenuOpen" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource MenuHoverBackgroundBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="FastEditTopLevelItemMenuItemTemplate" TargetType="{x:Type MenuItem}">
        <Border x:Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="6"
                Padding="{TemplateBinding Padding}">
            <ContentPresenter ContentSource="Header"
                              RecognizesAccessKey="True"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource MenuHoverBackgroundBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="FastEditSubmenuItemMenuItemTemplate" TargetType="{x:Type MenuItem}">
        <Border x:Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="4"
                Padding="{TemplateBinding Padding}"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid x:Name="IconSlot"
                      Width="22"
                      Height="22"
                      Margin="0,0,6,0"
                      VerticalAlignment="Center">
                    <Border x:Name="CheckBox"
                            Width="22"
                            Height="22"
                            BorderBrush="{DynamicResource MenuForegroundBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Opacity="0.75"
                            Visibility="Collapsed"/>
                    <TextBlock x:Name="CheckGlyph"
                               Text="&#xE73E;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="11"
                               Foreground="{DynamicResource MenuForegroundBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    <ContentPresenter x:Name="IconPresenter"
                                      ContentSource="Icon"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                </Grid>

                <ContentPresenter Grid.Column="1"
                                  Margin="0,0,16,0"
                                  ContentSource="Header"
                                  RecognizesAccessKey="True"
                                  VerticalAlignment="Center"/>

                <TextBlock x:Name="InputGestureTextBlock"
                           Grid.Column="2"
                           Margin="16,0,2,0"
                           Text="{TemplateBinding InputGestureText}"
                           Foreground="{DynamicResource MenuForegroundBrush}"
                           Opacity="0.72"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsCheckable" Value="True">
                <Setter TargetName="CheckBox" Property="Visibility" Value="Visible"/>
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsCheckable" Value="False"/>
                    <Condition Property="Icon" Value="{x:Null}"/>
                </MultiTrigger.Conditions>
                <Setter TargetName="IconSlot" Property="Visibility" Value="Collapsed"/>
            </MultiTrigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="CheckBox" Property="Background" Value="{DynamicResource TreeViewItemSelectedBrush}"/>
                <Setter TargetName="CheckBox" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
            </Trigger>
            <Trigger Property="Icon" Value="{x:Null}">
                <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="InputGestureText" Value="">
                <Setter TargetName="InputGestureTextBlock" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource MenuHoverBackgroundBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="FastEditSubmenuHeaderMenuItemTemplate" TargetType="{x:Type MenuItem}">
        <Border x:Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="4"
                Padding="{TemplateBinding Padding}"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>

                <ContentPresenter x:Name="HeaderIconPresenter"
                                  Grid.Column="0"
                                  Width="22"
                                  Height="22"
                                  Margin="0,0,6,0"
                                  ContentSource="Icon"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>

                <ContentPresenter Grid.Column="1"
                                  Margin="0,0,16,0"
                                  ContentSource="Header"
                                  RecognizesAccessKey="True"
                                  VerticalAlignment="Center"/>

                <TextBlock x:Name="HeaderInputGestureTextBlock"
                           Grid.Column="2"
                           Margin="16,0,2,0"
                           Text="{TemplateBinding InputGestureText}"
                           Foreground="{DynamicResource MenuForegroundBrush}"
                           Opacity="0.72"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="3"
                           Text="&#xE76C;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           Foreground="{DynamicResource MenuForegroundBrush}"
                           FontSize="10"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>

                <Popup x:Name="PART_Popup"
                       AllowsTransparency="True"
                       Focusable="False"
                       HorizontalOffset="-2"
                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                       Placement="Right"
                       PopupAnimation="Fade"
                       VerticalOffset="-4">
                    <Border Background="{DynamicResource MenuBackgroundBrush}"
                            BorderBrush="{DynamicResource MenuBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="4"
                            SnapsToDevicePixels="True">
                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                        KeyboardNavigation.TabNavigation="Cycle"/>
                    </Border>
                </Popup>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="Icon" Value="{x:Null}">
                <Setter TargetName="HeaderIconPresenter" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="InputGestureText" Value="">
                <Setter TargetName="HeaderInputGestureTextBlock" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource MenuHoverBackgroundBrush}"/>
            </Trigger>
            <Trigger Property="IsSubmenuOpen" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource MenuHoverBackgroundBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style TargetType="{x:Type Menu}">
        <Setter Property="Background" Value="{DynamicResource MenuBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource MenuForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource MenuBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource MenuForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template" Value="{StaticResource FastEditSubmenuItemMenuItemTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Role" Value="TopLevelHeader">
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="Template" Value="{StaticResource FastEditTopLevelHeaderMenuItemTemplate}"/>
            </Trigger>
            <Trigger Property="Role" Value="TopLevelItem">
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="Template" Value="{StaticResource FastEditTopLevelItemMenuItemTemplate}"/>
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
                <Setter Property="Template" Value="{StaticResource FastEditSubmenuHeaderMenuItemTemplate}"/>
            </Trigger>
            <Trigger Property="Role" Value="SubmenuItem">
                <Setter Property="Template" Value="{StaticResource FastEditSubmenuItemMenuItemTemplate}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="FastEditMenuSeparatorStyle" TargetType="{x:Type Separator}">
        <Setter Property="Margin" Value="0,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Height="1"
                            Margin="34,0,4,0"
                            Background="{DynamicResource MenuBorderBrush}"
                            Opacity="0.75"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Custom TabControl Style (editor tabs with accent border) -->
    <Style x:Key="EditorTabControlStyle" TargetType="TabControl">
        <Setter Property="Background" Value="{DynamicResource EditorBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="{DynamicResource TabBackgroundBrush}"
                                BorderThickness="0">
                            <TabPanel x:Name="HeaderPanel"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Background="Transparent"/>
                        </Border>
                        <Border Grid.Row="1"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              Margin="0"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Custom TabItem Style (editor tabs) -->
    <Style x:Key="EditorTabItemStyle" TargetType="TabItem">
        <Setter Property="Background" Value="{DynamicResource TabBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TabForegroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0,0,1,0"
                            BorderBrush="{DynamicResource TabBorderBrush}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter x:Name="ContentSite"
                                          ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource TabActiveBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TabActiveForegroundBrush}"/>
                            <Setter TargetName="Border" Property="BorderThickness" Value="0,2,1,0"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource MenuHoverBackgroundBrush}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource TabActiveBackgroundBrush}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Custom StatusBar Style -->
    <Style x:Key="EditorStatusBarStyle" TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource StatusBarBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource StatusBarForegroundBrush}"/>
    </Style>

    <!-- GridSplitter Style -->
    <Style TargetType="GridSplitter">
        <Setter Property="Background" Value="{DynamicResource PanelBorderBrush}"/>
    </Style>

    <!-- ===== SearchPanel Styles (explicit styles to bypass WPF UI's implicit TextBox style) ===== -->

    <Style x:Key="FastEditSearchTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Foreground" Value="{DynamicResource WindowForegroundBrush}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource WindowForegroundBrush}"/>
        <Setter Property="Background" Value="{DynamicResource EditorBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="MinWidth" Value="280"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FastEditSearchButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Foreground" Value="{DynamicResource WindowForegroundBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource TreeViewItemSelectedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FastEditSearchToggleButtonStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Foreground" Value="{DynamicResource WindowForegroundBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource TreeViewItemSelectedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FastEditSearchPanelStyle" TargetType="{x:Type search:SearchPanel}">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource WindowForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type search:SearchPanel}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="8,6"
                            Margin="0,0,20,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                        <StackPanel Orientation="Vertical">
                            <!-- Search Row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="PART_searchTextBox"
                                         Grid.Column="0"
                                         Style="{StaticResource FastEditSearchTextBoxStyle}">
                                    <TextBox.Text>
                                        <Binding Path="SearchPattern"
                                                 RelativeSource="{RelativeSource TemplatedParent}"
                                                 UpdateSourceTrigger="PropertyChanged">
                                            <Binding.ValidationRules>
                                                <ExceptionValidationRule/>
                                            </Binding.ValidationRules>
                                        </Binding>
                                    </TextBox.Text>
                                </TextBox>

                                <search:DropDownButton Grid.Column="2" Width="28" MinWidth="28" Height="28" MinHeight="28" Padding="0" VerticalAlignment="Center">
                                    <search:DropDownButton.DropDownContent>
                                        <Popup StaysOpen="False">
                                            <Border Background="{DynamicResource PanelBackgroundBrush}"
                                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10">
                                                <StackPanel>
                                                    <CheckBox Margin="0,0,0,6"
                                                              Foreground="{DynamicResource WindowForegroundBrush}"
                                                              IsChecked="{Binding MatchCase, RelativeSource={RelativeSource TemplatedParent}}"
                                                              Content="{Binding Localization.MatchCaseText, RelativeSource={RelativeSource TemplatedParent}}"/>
                                                    <CheckBox Margin="0,0,0,6"
                                                              Foreground="{DynamicResource WindowForegroundBrush}"
                                                              IsChecked="{Binding WholeWords, RelativeSource={RelativeSource TemplatedParent}}"
                                                              Content="{Binding Localization.MatchWholeWordsText, RelativeSource={RelativeSource TemplatedParent}}"/>
                                                    <CheckBox Foreground="{DynamicResource WindowForegroundBrush}"
                                                              IsChecked="{Binding UseRegex, RelativeSource={RelativeSource TemplatedParent}}"
                                                              Content="{Binding Localization.UseRegexText, RelativeSource={RelativeSource TemplatedParent}}"/>
                                                </StackPanel>
                                            </Border>
                                        </Popup>
                                    </search:DropDownButton.DropDownContent>
                                </search:DropDownButton>

                                <Button Grid.Column="4"
                                        Style="{StaticResource FastEditSearchButtonStyle}"
                                        Command="search:SearchCommands.FindPrevious"
                                        ToolTip="{Binding Localization.FindPreviousText, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Path Data="M 8 1 L 3 6 L 8 11"
                                          Stroke="{DynamicResource WindowForegroundBrush}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
                                </Button>

                                <Button Grid.Column="6"
                                        Style="{StaticResource FastEditSearchButtonStyle}"
                                        Command="search:SearchCommands.FindNext"
                                        ToolTip="{Binding Localization.FindNextText, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Path Data="M 3 1 L 8 6 L 3 11"
                                          Stroke="{DynamicResource WindowForegroundBrush}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
                                </Button>

                                <!-- Toggle Replace row -->
                                <ToggleButton x:Name="PART_toggleReplace"
                                              Grid.Column="8"
                                              Style="{StaticResource FastEditSearchToggleButtonStyle}"
                                              Width="28" Height="28"
                                              ToolTip="Toggle Replace">
                                    <Path Data="M 2 4 L 10 4 M 6 0 L 10 4 L 6 8"
                                          Stroke="{DynamicResource WindowForegroundBrush}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
                                </ToggleButton>

                                <Button Grid.Column="10"
                                        Style="{StaticResource FastEditSearchButtonStyle}"
                                        Width="24" Height="24"
                                        Command="search:SearchCommands.CloseSearchPanel"
                                        ToolTip="Close">
                                    <Path Data="M 2 2 L 10 10 M 10 2 L 2 10"
                                          Stroke="{DynamicResource WindowForegroundBrush}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
                                </Button>
                            </Grid>

                            <!-- Replace Row (toggled by PART_toggleReplace) -->
                            <Grid x:Name="PART_replaceRow" Margin="0,6,0,0" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="PART_replaceTextBox"
                                         Grid.Column="0"
                                         Style="{StaticResource FastEditSearchTextBoxStyle}"/>

                                <Button x:Name="PART_replaceButton"
                                        Grid.Column="2"
                                        Style="{StaticResource FastEditSearchButtonStyle}"
                                        Width="Auto" Padding="8,0"
                                        ToolTip="Replace (Enter)">
                                    <TextBlock Text="Replace"
                                               Foreground="{DynamicResource WindowForegroundBrush}"
                                               FontSize="11"/>
                                </Button>

                                <Button x:Name="PART_replaceAllButton"
                                        Grid.Column="4"
                                        Style="{StaticResource FastEditSearchButtonStyle}"
                                        Width="Auto" Padding="8,0"
                                        ToolTip="Replace All">
                                    <TextBlock Text="All"
                                               Foreground="{DynamicResource WindowForegroundBrush}"
                                               FontSize="11"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger SourceName="PART_toggleReplace" Property="IsChecked" Value="True">
                            <Setter TargetName="PART_replaceRow" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
