<ui:FluentWindow x:Class="FastEdit.Views.Dialogs.FilterEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Add Filter"
        Width="420"
        Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource WindowForegroundBrush}">

    <StackPanel Margin="16,40,16,16" Background="{DynamicResource WindowBackgroundBrush}">
        <TextBlock Text="Pattern" FontWeight="SemiBold" Margin="0,0,0,4"
                   Foreground="{DynamicResource WindowForegroundBrush}"/>
        <TextBox x:Name="PatternBox" Margin="0,0,0,12"
                  VerticalContentAlignment="Center" Height="32"
                  Background="{DynamicResource EditorBackgroundBrush}"
                  Foreground="{DynamicResource WindowForegroundBrush}"
                  BorderBrush="{DynamicResource PanelBorderBrush}"
                  FontFamily="Cascadia Code, Consolas"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <CheckBox x:Name="RegexCheck" Content="Regular expression" Margin="0,0,20,0"
                      Foreground="{DynamicResource WindowForegroundBrush}"/>
            <CheckBox x:Name="CaseCheck" Content="Case sensitive"
                      Foreground="{DynamicResource WindowForegroundBrush}"/>
        </StackPanel>

        <CheckBox x:Name="ExcludeCheck" Content="Excluding filter (suppresses matching lines)" Margin="0,0,0,12"
                  Foreground="{DynamicResource WindowForegroundBrush}"/>

        <TextBlock Text="Highlight Color" FontWeight="SemiBold" Margin="0,0,0,6"
                   Foreground="{DynamicResource WindowForegroundBrush}"/>
        <WrapPanel x:Name="ColorPalette" Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Click="OK_Click" IsDefault="True" Padding="24,8" Margin="0,0,8,0"/>
            <Button Content="Cancel" Click="Cancel_Click" IsCancel="True" Padding="24,8"/>
        </StackPanel>
    </StackPanel>
</ui:FluentWindow>
