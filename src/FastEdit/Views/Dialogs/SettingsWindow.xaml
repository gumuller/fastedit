<ui:FluentWindow x:Class="FastEdit.Views.Dialogs.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Settings"
        Width="520"
        Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource WindowForegroundBrush}">

    <Grid Margin="16,36,16,16" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" x:Name="SettingsTabs">
            <!-- Editor + Appearance + General -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8">
                        <!-- Editor Section -->
                        <TextBlock Text="Editor" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"
                                   Foreground="{DynamicResource WindowForegroundBrush}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Font size" Width="170" VerticalAlignment="Center"
                                       Foreground="{DynamicResource WindowForegroundBrush}"/>
                            <Button Content="−" Width="28" Height="28" Click="FontSizeDown_Click" Margin="0,0,4,0"/>
                            <TextBox x:Name="FontSizeBox" Width="50" TextAlignment="Center"
                                     VerticalContentAlignment="Center" Height="28"/>
                            <Button Content="+" Width="28" Height="28" Click="FontSizeUp_Click" Margin="4,0,0,0"/>
                        </StackPanel>

                        <CheckBox x:Name="WordWrapCheck" Content="Word wrap" Margin="0,4"
                                  Foreground="{DynamicResource WindowForegroundBrush}"/>
                        <CheckBox x:Name="ShowWhitespaceCheck" Content="Show whitespace" Margin="0,4"
                                  Foreground="{DynamicResource WindowForegroundBrush}"/>
                        <CheckBox x:Name="IndentGuidesCheck" Content="Show indent guides" Margin="0,4"
                                  Foreground="{DynamicResource WindowForegroundBrush}"/>
                        <CheckBox x:Name="CodeFoldingCheck" Content="Code folding" Margin="0,4"
                                  Foreground="{DynamicResource WindowForegroundBrush}"/>
                        <CheckBox x:Name="MinimapCheck" Content="Show minimap" Margin="0,4"
                                  Foreground="{DynamicResource WindowForegroundBrush}"/>
                        <CheckBox x:Name="AutoReloadCheck" Content="Auto-reload files" Margin="0,4"
                                  Foreground="{DynamicResource WindowForegroundBrush}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                            <TextBlock Text="Tab size" Width="170" VerticalAlignment="Center"
                                       Foreground="{DynamicResource WindowForegroundBrush}"/>
                            <ComboBox x:Name="TabSizeCombo" Width="80">
                                <ComboBoxItem Content="2" Tag="2"/>
                                <ComboBoxItem Content="4" Tag="4"/>
                                <ComboBoxItem Content="8" Tag="8"/>
                            </ComboBox>
                        </StackPanel>

                        <CheckBox x:Name="UseTabsCheck" Content="Use tabs (instead of spaces)" Margin="0,4"
                                  Foreground="{DynamicResource WindowForegroundBrush}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                            <TextBlock Text="Cursor style" Width="170" VerticalAlignment="Center"
                                       Foreground="{DynamicResource WindowForegroundBrush}"/>
                            <ComboBox x:Name="CursorStyleCombo" Width="160">
                                <ComboBoxItem Content="Line" Tag="Line"/>
                                <ComboBoxItem Content="Line Thin" Tag="LineThin"/>
                                <ComboBoxItem Content="Block" Tag="Block"/>
                                <ComboBoxItem Content="Underscore" Tag="Underscore"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Appearance Section -->
                        <Separator Margin="0,12"/>
                        <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="16" Margin="0,12,0,12"
                                   Foreground="{DynamicResource WindowForegroundBrush}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Theme" Width="170" VerticalAlignment="Center"
                                       Foreground="{DynamicResource WindowForegroundBrush}"/>
                            <ComboBox x:Name="ThemeCombo" Width="200"
                                      DisplayMemberPath="DisplayName"/>
                        </StackPanel>

                        <!-- General Section -->
                        <Separator Margin="0,12"/>
                        <TextBlock Text="General" FontWeight="SemiBold" FontSize="16" Margin="0,12,0,12"
                                   Foreground="{DynamicResource WindowForegroundBrush}"/>

                        <CheckBox x:Name="CheckUpdatesCheck" Content="Check for updates on startup" Margin="0,4"
                                  Foreground="{DynamicResource WindowForegroundBrush}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                            <TextBlock Text="Auto-save interval (s)" Width="170" VerticalAlignment="Center"
                                       Foreground="{DynamicResource WindowForegroundBrush}"/>
                            <TextBox x:Name="AutoSaveBox" Width="60"
                                     TextAlignment="Center" VerticalContentAlignment="Center" Height="28"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Keyboard Shortcuts -->
            <TabItem Header="Keyboard Shortcuts">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="ShortcutsGrid" Grid.Row="0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              Background="{DynamicResource PanelBackgroundBrush}"
                              Foreground="{DynamicResource WindowForegroundBrush}"
                              BorderBrush="{DynamicResource PanelBorderBrush}"
                              BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Shortcut" Binding="{Binding Gesture}" Width="150" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Record Shortcut" Click="RecordShortcut_Click" Padding="12,6" Margin="0,0,8,0"/>
                        <Button Content="Reset to Defaults" Click="ResetShortcuts_Click" Padding="12,6"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Click="Save_Click" IsDefault="True" Padding="24,8" Margin="0,0,8,0"/>
            <Button Content="Cancel" Click="Cancel_Click" IsCancel="True" Padding="24,8"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
