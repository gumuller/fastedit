<Window x:Class="FastEdit.Views.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About FastEdit"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource WindowForegroundBrush}">
    <Grid Margin="24,20,24,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Image Grid.Column="0" Grid.RowSpan="2"
               Source="pack://application:,,,/fastedit-icon.png"
               Width="96" Height="96"
               VerticalAlignment="Top"
               Margin="0,0,20,0"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <StackPanel Grid.Column="1" Grid.Row="0">
            <TextBlock Text="FastEdit"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="0,-4,0,0"/>
            <TextBlock x:Name="VersionText"
                       FontSize="13"
                       Opacity="0.75"
                       Margin="0,2,0,10"/>
            <TextBlock TextWrapping="Wrap"
                       Text="A fast, lightweight text and hex editor for Windows."
                       Margin="0,0,0,10"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Features" FontWeight="SemiBold" Margin="0,4,0,4"/>
            <TextBlock TextWrapping="Wrap" Opacity="0.85" LineHeight="18">
                Syntax highlighting for 20+ languages &#x2022; Hex editor for binary files &#x2022;
                9 built-in themes &#x2022; Virtual scrolling for large files &#x2022;
                Session restore &#x2022; Find &amp; Replace, Find in Files &#x2022;
                Command Palette (Ctrl+Shift+P) &#x2022; Auto-complete (Ctrl+Space) &#x2022;
                Code folding &#x2022; Git branch detection &#x2022; Built-in terminal &#x2022;
                Split editor view &#x2022; File comparison
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="GitHub"
                    Click="GitHub_Click"
                    Padding="16,6"
                    Margin="0,0,8,0"/>
            <Button Content="OK"
                    Click="Ok_Click"
                    IsDefault="True"
                    IsCancel="True"
                    Padding="24,6"/>
        </StackPanel>
    </Grid>
</Window>
