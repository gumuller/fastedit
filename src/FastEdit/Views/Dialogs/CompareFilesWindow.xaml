<Window x:Class="FastEdit.Views.Dialogs.CompareFilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Compare Files"
        Height="650" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource EditorBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- File Labels -->
        <Grid Grid.Row="0" Margin="8,8,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="LeftLabel" Grid.Column="0"
                       Foreground="{DynamicResource WindowForegroundBrush}"
                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
            <TextBlock x:Name="RightLabel" Grid.Column="2"
                       Foreground="{DynamicResource WindowForegroundBrush}"
                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- Side-by-side Editors -->
        <Grid Grid.Row="1" Margin="8,0,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <avalonedit:TextEditor x:Name="LeftEditor" Grid.Column="0"
                                   IsReadOnly="True"
                                   ShowLineNumbers="True"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="13"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto"
                                   Background="{DynamicResource EditorBackgroundBrush}"
                                   Foreground="{DynamicResource EditorForegroundBrush}"/>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          Background="{DynamicResource PanelBorderBrush}"/>

            <avalonedit:TextEditor x:Name="RightEditor" Grid.Column="2"
                                   IsReadOnly="True"
                                   ShowLineNumbers="True"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="13"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto"
                                   Background="{DynamicResource EditorBackgroundBrush}"
                                   Foreground="{DynamicResource EditorForegroundBrush}"/>
        </Grid>

        <!-- Status -->
        <Border Grid.Row="2" Background="{DynamicResource StatusBarBackgroundBrush}" Padding="8,4">
            <TextBlock x:Name="DiffStatus"
                       Foreground="{DynamicResource StatusBarForegroundBrush}"
                       FontSize="12"/>
        </Border>
    </Grid>
</Window>
