<UserControl x:Class="FastEdit.Views.Controls.CommandRunnerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Border Background="{DynamicResource EditorBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource MenuBackgroundBrush}" Padding="8,4">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Terminal" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource EditorForegroundBrush}"/>
                        <TextBlock Text=" — " FontSize="11"
                                   Foreground="{DynamicResource EditorForegroundBrush}" Opacity="0.5"/>
                        <TextBlock x:Name="ShellTypeLabel" Text="PowerShell" FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="ClearButton" Content="Clear" Click="Clear_Click"
                                Background="Transparent" BorderThickness="0" Padding="8,2"
                                FontSize="11" Foreground="{DynamicResource EditorForegroundBrush}" Cursor="Hand"/>
                        <Button x:Name="StopButton" Content="Stop" Click="Stop_Click"
                                Background="Transparent" BorderThickness="0" Padding="8,2"
                                FontSize="11" Foreground="{DynamicResource EditorForegroundBrush}" Cursor="Hand"
                                IsEnabled="False"/>
                        <Button x:Name="CloseButton" Content="✕" Click="Close_Click"
                                Background="Transparent" BorderThickness="0" Padding="8,2"
                                FontSize="11" Foreground="{DynamicResource EditorForegroundBrush}" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Output -->
            <ScrollViewer x:Name="OutputScroll" Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="OutputBox"
                         IsReadOnly="True"
                         BorderThickness="0"
                         FontFamily="Cascadia Code,Consolas,Courier New"
                         FontSize="12"
                         Background="{DynamicResource EditorBackgroundBrush}"
                         Foreground="{DynamicResource EditorForegroundBrush}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Disabled"
                         Padding="8,4"/>
            </ScrollViewer>

            <!-- Input -->
            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PromptLabel" Grid.Column="0"
                               FontFamily="Cascadia Code,Consolas"
                               FontSize="12" Padding="8,6,4,6" VerticalAlignment="Center"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBox x:Name="InputBox" Grid.Column="1"
                             FontFamily="Cascadia Code,Consolas,Courier New"
                             FontSize="12"
                             BorderThickness="0"
                             Background="{DynamicResource EditorBackgroundBrush}"
                             Foreground="{DynamicResource EditorForegroundBrush}"
                             Padding="0,6"
                             KeyDown="InputBox_KeyDown"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
