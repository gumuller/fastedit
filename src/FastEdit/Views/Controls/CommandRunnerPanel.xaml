<UserControl x:Class="FastEdit.Views.Controls.CommandRunnerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Border Background="{DynamicResource EditorBackgroundBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="0,1,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource MenuBackgroundBrush}" Padding="8,4">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Terminal" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource EditorForegroundBrush}"/>
                        <TextBlock Text=" — " FontSize="11"
                                   Foreground="{DynamicResource EditorForegroundBrush}" Opacity="0.5"/>
                        <TextBlock x:Name="ShellTypeLabel" Text="PowerShell" FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="ClearButton" Content="Clear" Click="Clear_Click"
                                Background="Transparent" BorderThickness="0" Padding="8,2"
                                FontSize="11" Foreground="{DynamicResource EditorForegroundBrush}" Cursor="Hand"/>
                        <Button x:Name="StopButton" Content="Stop" Click="Stop_Click"
                                Background="Transparent" BorderThickness="0" Padding="8,2"
                                FontSize="11" Foreground="{DynamicResource EditorForegroundBrush}" Cursor="Hand"
                                IsEnabled="False"/>
                        <Button x:Name="CloseButton" Content="✕" Click="Close_Click"
                                Background="Transparent" BorderThickness="0" Padding="8,2"
                                FontSize="11" Foreground="{DynamicResource EditorForegroundBrush}" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Terminal Tab Strip -->
            <Border Grid.Row="1" Background="{DynamicResource MenuBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,0,0,1">
                <StackPanel x:Name="TabStripPanel" Orientation="Horizontal"/>
            </Border>

            <!-- Terminal area using RichTextBox -->
            <RichTextBox x:Name="TerminalBox" Grid.Row="2"
                         BorderThickness="0"
                         FontFamily="Cascadia Code,Consolas,Courier New"
                         FontSize="12"
                         Background="{DynamicResource EditorBackgroundBrush}"
                         Foreground="{DynamicResource EditorForegroundBrush}"
                         CaretBrush="{DynamicResource EditorForegroundBrush}"
                         SelectionBrush="{DynamicResource AccentBrush}"
                         AcceptsReturn="False"
                         AcceptsTab="False"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Padding="8,4"
                         IsUndoEnabled="False"
                         PreviewKeyDown="TerminalBox_PreviewKeyDown"
                         PreviewTextInput="TerminalBox_PreviewTextInput"
                         PreviewMouseDown="TerminalBox_PreviewMouseDown"/>
        </Grid>
    </Border>
</UserControl>
