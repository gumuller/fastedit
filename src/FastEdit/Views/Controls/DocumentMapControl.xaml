<UserControl x:Class="FastEdit.Views.Controls.DocumentMapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="100"
             Cursor="Hand"
             ClipToBounds="True"
             MouseLeftButtonDown="OnMouseDown"
             MouseMove="OnMouseMove"
             MouseLeftButtonUp="OnMouseUp">
    <Grid>
        <Canvas x:Name="MapCanvas" Background="{DynamicResource EditorBackgroundBrush}"/>
        <!-- Viewport indicator -->
        <Border x:Name="ViewportIndicator"
                Background="{DynamicResource EditorSelectionBackgroundBrush}"
                Opacity="0.4"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                IsHitTestVisible="False"/>
    </Grid>
</UserControl>
