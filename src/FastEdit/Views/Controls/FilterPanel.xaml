<UserControl x:Class="FastEdit.Views.Controls.FilterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource PanelBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,0,0,1"
                Padding="8,5">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="✕" Click="Close_Click"
                        Background="Transparent" BorderThickness="0" Padding="6,2"
                        Foreground="{DynamicResource TabForegroundBrush}" Cursor="Hand"
                        FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="LINE FILTERS" FontWeight="SemiBold" FontSize="11"
                           Foreground="{DynamicResource TabForegroundBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="MatchCountText" FontSize="11"
                           Foreground="{DynamicResource TabForegroundBrush}"
                           VerticalAlignment="Center" Opacity="0.7"/>
            </DockPanel>
        </Border>

        <!-- Filter List -->
        <ListView Grid.Row="1" x:Name="FilterList"
                  Background="Transparent"
                  BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  SelectionMode="Single"
                  MouseDoubleClick="FilterList_DoubleClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2,1">
                        <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                  VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Border Width="14" Height="14" CornerRadius="2" Margin="0,0,6,0"
                                VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding BackgroundColor}"/>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="{Binding Pattern}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource WindowForegroundBrush}"
                                   FontFamily="Cascadia Code, Consolas" FontSize="12"/>
                        <TextBlock Text=" [Exclude]" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TabForegroundBrush}"
                                   FontSize="11" Opacity="0.6">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExcluding}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text=" (Regex)" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TabForegroundBrush}"
                                   FontSize="11" Opacity="0.6">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRegex}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="4,2"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Bottom Toolbar -->
        <Border Grid.Row="2" Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,1,0,0"
                Padding="6,4">
            <WrapPanel>
                <Button Click="Add_Click" Padding="8,3" Margin="0,0,4,0"
                        FontSize="11" Background="Transparent" Foreground="{DynamicResource WindowForegroundBrush}" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Margin="0,0,4,0"/>
                        <TextBlock Text="Add"/>
                    </StackPanel>
                </Button>
                <Button Click="Edit_Click" Padding="8,3" Margin="0,0,4,0"
                        FontSize="11" Background="Transparent" Foreground="{DynamicResource WindowForegroundBrush}" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Margin="0,0,4,0"/>
                        <TextBlock Text="Edit"/>
                    </StackPanel>
                </Button>
                <Button Click="Remove_Click" Padding="8,3" Margin="0,0,4,0"
                        FontSize="11" Background="Transparent" Foreground="{DynamicResource WindowForegroundBrush}" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Margin="0,0,4,0"/>
                        <TextBlock Text="Remove"/>
                    </StackPanel>
                </Button>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="4,2"/>
                <Button Click="PrevMatch_Click" Padding="8,3" Margin="0,0,4,0"
                        FontSize="11" Background="Transparent" Foreground="{DynamicResource WindowForegroundBrush}" Cursor="Hand"
                        ToolTip="Jump to previous matching line (Shift+F3)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74A;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Margin="0,0,4,0"/>
                        <TextBlock Text="Prev"/>
                    </StackPanel>
                </Button>
                <Button Click="NextMatch_Click" Padding="8,3" Margin="0,0,4,0"
                        FontSize="11" Background="Transparent" Foreground="{DynamicResource WindowForegroundBrush}" Cursor="Hand"
                        ToolTip="Jump to next matching line (F3)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Margin="0,0,4,0"/>
                        <TextBlock Text="Next"/>
                    </StackPanel>
                </Button>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="4,2"/>
                <ToggleButton x:Name="ShowOnlyToggle"
                              Click="ShowOnlyToggle_Click" Padding="8,3" Margin="0,0,4,0"
                              FontSize="11" Background="Transparent" Foreground="{DynamicResource WindowForegroundBrush}" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE890;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Margin="0,0,4,0"/>
                        <TextBlock Text="Show Only Filtered"/>
                    </StackPanel>
                </ToggleButton>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="4,2"/>
                <Button Content="Enable All" Click="EnableAll_Click" Padding="8,3" Margin="0,0,4,0"
                        FontSize="11" Background="Transparent" Foreground="{DynamicResource WindowForegroundBrush}" Cursor="Hand"/>
                <Button Content="Disable All" Click="DisableAll_Click" Padding="8,3" Margin="0,0,4,0"
                        FontSize="11" Background="Transparent" Foreground="{DynamicResource WindowForegroundBrush}" Cursor="Hand"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="4,2"/>
                <Button Click="SaveFilters_Click" Padding="8,3" Margin="0,0,4,0"
                        FontSize="11" Background="Transparent" Foreground="{DynamicResource WindowForegroundBrush}" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Margin="0,0,4,0"/>
                        <TextBlock Text="Save..."/>
                    </StackPanel>
                </Button>
                <Button Click="LoadFilters_Click" Padding="8,3" Margin="0,0,4,0"
                        FontSize="11" Background="Transparent" Foreground="{DynamicResource WindowForegroundBrush}" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Margin="0,0,4,0"/>
                        <TextBlock Text="Load..."/>
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>
