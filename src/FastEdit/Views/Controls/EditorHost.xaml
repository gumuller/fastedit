<UserControl x:Class="FastEdit.Views.Controls.EditorHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:controls="clr-namespace:FastEdit.Views.Controls">

    <Grid>
        <!-- Text Editor (shown when not binary mode) -->
        <avalonedit:TextEditor x:Name="TextEditor"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               FontSize="14"
                               ShowLineNumbers="True"
                               Background="{DynamicResource EditorBackgroundBrush}"
                               Foreground="{DynamicResource EditorForegroundBrush}"
                               LineNumbersForeground="{DynamicResource EditorLineNumbersForegroundBrush}"
                               Visibility="Collapsed">
            <avalonedit:TextEditor.Options>
                <avalonedit:TextEditorOptions ShowTabs="False"
                                              ShowSpaces="False"
                                              ShowEndOfLine="False"
                                              EnableHyperlinks="True"
                                              EnableEmailHyperlinks="True"
                                              WordWrapIndentation="4"
                                              ConvertTabsToSpaces="True"
                                              IndentationSize="4"/>
            </avalonedit:TextEditor.Options>
        </avalonedit:TextEditor>

        <!-- Hex Editor (shown when binary mode) -->
        <controls:HexEditorControl x:Name="HexEditor"
                                   Visibility="Collapsed"/>
    </Grid>
</UserControl>
