<UserControl x:Class="FastEdit.Views.Controls.HexEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource EditorBackgroundBrush}"
             Focusable="True"
             KeyDown="HexCanvas_KeyDown"
             MouseLeftButtonDown="HexCanvas_MouseDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Hex Search Bar -->
        <Border x:Name="HexSearchBar" Grid.Row="0" Grid.ColumnSpan="2"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Find:" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource WindowForegroundBrush}"/>
                <TextBox x:Name="HexSearchBox" Width="200" Height="26"
                         VerticalContentAlignment="Center"
                         KeyDown="HexSearchBox_KeyDown"
                         FontFamily="Cascadia Code, Consolas"
                         ToolTip="Enter hex bytes (e.g. FF 00 AB) or text in quotes (e.g. &quot;hello&quot;)"/>
                <Button Content="Find Next" Click="HexSearchNext_Click" Padding="8,4" Margin="6,0,0,0" Height="26"/>
                <Button Content="Find Prev" Click="HexSearchPrev_Click" Padding="8,4" Margin="4,0,0,0" Height="26"/>
                <TextBlock x:Name="HexSearchStatus" VerticalAlignment="Center" Margin="8,0,0,0"
                           Foreground="{DynamicResource TabForegroundBrush}" FontSize="11"/>
                <Button Content="✕" Click="HexSearchClose_Click" Background="Transparent"
                        BorderThickness="0" Padding="6,2" Margin="8,0,0,0" Height="26"
                        Foreground="{DynamicResource TabForegroundBrush}" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Hex Content Canvas -->
        <Canvas x:Name="HexCanvas"
                Grid.Row="1" Grid.Column="0"
                ClipToBounds="True"
                Focusable="True"
                MouseWheel="HexCanvas_MouseWheel"
                MouseLeftButtonDown="HexCanvas_MouseDown"/>

        <!-- Vertical ScrollBar -->
        <ScrollBar x:Name="VerticalScrollBar"
                   Grid.Row="1" Grid.Column="1"
                   Orientation="Vertical"
                   Minimum="0"
                   Maximum="0"
                   ViewportSize="1"
                   Value="0"
                   LargeChange="1"
                   SmallChange="1"
                   ValueChanged="ScrollBar_ValueChanged"/>
    </Grid>
</UserControl>
