<UserControl x:Class="FastEdit.Views.Controls.HexEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource EditorBackgroundBrush}"
             Focusable="True"
             KeyDown="HexCanvas_KeyDown"
             MouseLeftButtonDown="HexCanvas_MouseDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Hex Content Canvas -->
        <Canvas x:Name="HexCanvas"
                Grid.Column="0"
                ClipToBounds="True"
                Focusable="True"
                MouseWheel="HexCanvas_MouseWheel"
                MouseLeftButtonDown="HexCanvas_MouseDown"/>

        <!-- Hex Search Panel (floating overlay, matches text editor search style) -->
        <Border x:Name="HexSearchBar"
                Grid.Column="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8,6"
                Margin="0,0,20,0"
                Visibility="Collapsed">
            <StackPanel Orientation="Vertical">
                <!-- Search Row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search TextBox -->
                    <TextBox x:Name="HexSearchBox" Grid.Column="0"
                             Style="{StaticResource FastEditSearchTextBoxStyle}"
                             MinWidth="220"
                             KeyDown="HexSearchBox_KeyDown"
                             FontFamily="Cascadia Code, Consolas"
                             ToolTip="Hex bytes (FF 00 AB) or quoted text (&quot;hello&quot;)"/>

                    <!-- Search Mode Indicator -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource EditorBackgroundBrush}"
                            CornerRadius="4" Padding="6,4"
                            VerticalAlignment="Center"
                            ToolTip="Search supports hex bytes or quoted ASCII text">
                        <TextBlock x:Name="SearchModeText" Text="HEX"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="10" FontWeight="SemiBold"/>
                    </Border>

                    <!-- Find Previous -->
                    <Button Grid.Column="4"
                            Style="{StaticResource FastEditSearchButtonStyle}"
                            Click="HexSearchPrev_Click"
                            ToolTip="Find Previous (Shift+Enter)">
                        <Path Data="M 8 1 L 3 6 L 8 11"
                              Stroke="{DynamicResource WindowForegroundBrush}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    </Button>

                    <!-- Find Next -->
                    <Button Grid.Column="6"
                            Style="{StaticResource FastEditSearchButtonStyle}"
                            Click="HexSearchNext_Click"
                            ToolTip="Find Next (Enter)">
                        <Path Data="M 3 1 L 8 6 L 3 11"
                              Stroke="{DynamicResource WindowForegroundBrush}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    </Button>

                    <!-- Close -->
                    <Button Grid.Column="8"
                            Style="{StaticResource FastEditSearchButtonStyle}"
                            Width="24" Height="24"
                            Click="HexSearchClose_Click"
                            ToolTip="Close (Escape)">
                        <Path Data="M 2 2 L 10 10 M 10 2 L 2 10"
                              Stroke="{DynamicResource WindowForegroundBrush}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    </Button>
                </Grid>

                <!-- Match Count -->
                <TextBlock x:Name="HexSearchStatus"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource TabForegroundBrush}"
                           FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- Vertical ScrollBar -->
        <ScrollBar x:Name="VerticalScrollBar"
                   Grid.Column="1"
                   Orientation="Vertical"
                   Minimum="0"
                   Maximum="0"
                   ViewportSize="1"
                   Value="0"
                   LargeChange="1"
                   SmallChange="1"
                   ValueChanged="ScrollBar_ValueChanged"/>
    </Grid>
</UserControl>
