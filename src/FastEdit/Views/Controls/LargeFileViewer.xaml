<UserControl x:Class="FastEdit.Views.Controls.LargeFileViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FastEdit.Views.Controls"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             Background="{DynamicResource EditorBackgroundBrush}"
             Foreground="{DynamicResource EditorForegroundBrush}"
             FontFamily="Consolas"
             FontSize="13"
             Focusable="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Viewer + scrollbar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="RenderHost" Grid.Column="0"
                    Background="{DynamicResource EditorBackgroundBrush}"
                    SizeChanged="RenderHost_SizeChanged"
                    MouseWheel="RenderHost_MouseWheel"
                    Focusable="True"
                    ClipToBounds="True"/>

            <ScrollBar x:Name="VScroll" Grid.Column="1" Orientation="Vertical"
                       Width="16" Minimum="0" Maximum="100" Value="0"
                       SmallChange="1" LargeChange="10"
                       Scroll="VScroll_Scroll"/>

            <!-- Find and Go To overlay -->
            <Border x:Name="FindBar"
                    Grid.Column="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8,6"
                    Margin="0,8,20,0"
                    Visibility="Collapsed">
                <StackPanel Orientation="Vertical">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="FindBox"
                                 Grid.Column="0"
                                 Style="{StaticResource FastEditSearchTextBoxStyle}"
                                 KeyDown="FindBox_KeyDown"
                                 ToolTip="Find (Enter = next, Shift+Enter = previous, Esc = close)"/>

                        <CheckBox x:Name="CaseSensitiveBox"
                                  Grid.Column="2"
                                  Content="Aa"
                                  Foreground="{DynamicResource WindowForegroundBrush}"
                                  VerticalAlignment="Center"
                                  ToolTip="Match case"/>

                        <Button Grid.Column="4"
                                Style="{StaticResource FastEditSearchButtonStyle}"
                                Click="FindPrev_Click"
                                ToolTip="Previous (Shift+Enter)">
                            <Path Data="M 8 1 L 3 6 L 8 11"
                                  Stroke="{DynamicResource WindowForegroundBrush}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Button>

                        <Button Grid.Column="6"
                                Style="{StaticResource FastEditSearchButtonStyle}"
                                Click="FindNext_Click"
                                ToolTip="Next (Enter)">
                            <Path Data="M 3 1 L 8 6 L 3 11"
                                  Stroke="{DynamicResource WindowForegroundBrush}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Button>

                        <Button Grid.Column="8"
                                Style="{StaticResource FastEditSearchButtonStyle}"
                                Width="24"
                                Height="24"
                                Click="CloseFindBar_Click"
                                ToolTip="Close (Escape)">
                            <Path Data="M 2 2 L 10 10 M 10 2 L 2 10"
                                  Stroke="{DynamicResource WindowForegroundBrush}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Button>

                        <TextBlock x:Name="FindStatusText"
                                   Grid.Column="10"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TabForegroundBrush}"
                                   FontSize="11"/>
                    </Grid>

                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Go to line"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TabForegroundBrush}"
                                   FontSize="11"/>
                        <TextBox x:Name="GotoBox"
                                 Grid.Column="2"
                                 Style="{StaticResource FastEditSearchTextBoxStyle}"
                                 Width="88"
                                 MinWidth="88"
                                 KeyDown="GotoBox_KeyDown"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer status -->
        <Border Grid.Row="1" Background="{DynamicResource StatusBarBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,1,0,0" Padding="8,3">
            <TextBlock x:Name="FooterText"
                       Foreground="{DynamicResource StatusForegroundBrush}"/>
        </Border>
    </Grid>
</UserControl>
