<ui:FluentWindow x:Class="FastEdit.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:FastEdit.Views.Controls"
        xmlns:vm="clr-namespace:FastEdit.ViewModels"
        xmlns:infra="clr-namespace:FastEdit.Infrastructure"
        mc:Ignorable="d"
        x:Name="RootWindow"
        Title="FastEdit"
        Height="700"
        Width="1100"
        MinHeight="400"
        MinWidth="600"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <ui:FluentWindow.Resources>
        <infra:BindingProxy x:Key="ViewModelProxy" Data="{Binding}"/>
    </ui:FluentWindow.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveAsCommand}"/>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewFileCommand}"/>
        <KeyBinding Key="W" Modifiers="Control" Command="{Binding CloseTabCommand}"/>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding FindCommand}"/>
        <KeyBinding Key="H" Modifiers="Control" Command="{Binding ReplaceCommand}"/>
        <KeyBinding Key="G" Modifiers="Control" Command="{Binding GoToLineCommand}"/>
        <KeyBinding Key="D" Modifiers="Control+Shift" Command="{Binding DuplicateLineCommand}"/>
        <KeyBinding Key="Up" Modifiers="Alt" Command="{Binding MoveLineUpCommand}"/>
        <KeyBinding Key="Down" Modifiers="Alt" Command="{Binding MoveLineDownCommand}"/>
        <KeyBinding Key="OemPlus" Modifiers="Control" Command="{Binding ZoomInCommand}"/>
        <KeyBinding Key="OemMinus" Modifiers="Control" Command="{Binding ZoomOutCommand}"/>
        <KeyBinding Key="D0" Modifiers="Control" Command="{Binding ResetZoomCommand}"/>
        <KeyBinding Key="F" Modifiers="Control+Shift" Command="{Binding FindInFilesCommand}"/>
        <KeyBinding Key="F2" Modifiers="Control" Command="{Binding ToggleBookmarkCommand}"/>
        <KeyBinding Key="F2" Command="{Binding NextBookmarkCommand}"/>
        <KeyBinding Key="F2" Modifiers="Shift" Command="{Binding PrevBookmarkCommand}"/>
        <KeyBinding Key="P" Modifiers="Control+Shift" Command="{Binding CommandPaletteCommand}"/>
        <KeyBinding Key="Space" Modifiers="Control" Command="{Binding ShowCompletionCommand}"/>
        <KeyBinding Key="OemTilde" Modifiers="Control" Command="{Binding ToggleCommandRunnerCommand}"/>
        <KeyBinding Key="OemPipe" Modifiers="Control" Command="{Binding ToggleSplitViewCommand}"/>
        <KeyBinding Key="P" Modifiers="Control" Command="{Binding PrintCommand}"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding SelectNextOccurrenceCommand}"/>
        <KeyBinding Key="L" Modifiers="Control+Shift" Command="{Binding SelectAllOccurrencesCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Row: Icon + Tabs + New Tab + drag area + caption buttons -->
        <Grid Grid.Row="0" Background="{DynamicResource TabBackgroundBrush}"
              x:Name="TitleBarGrid" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- App Icon -->
            <Image Grid.Column="0" x:Name="AppIcon" Width="24" Height="24" Margin="8,4,6,4"
                   VerticalAlignment="Center" MouseLeftButtonDown="AppIcon_MouseLeftButtonDown"/>

            <!-- Tab Strip -->
            <ItemsControl Grid.Column="1" x:Name="TabStrip"
                          ItemsSource="{Binding Tabs}" VerticalAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderThickness="0,0,1,0"
                                BorderBrush="{DynamicResource TabBorderBrush}"
                                Padding="12,6"
                                Cursor="Hand"
                                MouseLeftButtonDown="TabHeader_MouseLeftButtonDown"
                                MouseMove="TabHeader_MouseMove"
                                AllowDrop="True"
                                DragOver="TabHeader_DragOver"
                                Drop="TabHeader_Drop"
                                Tag="{Binding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding FileName}" Margin="0,0,8,0"
                                           Foreground="{DynamicResource TabForegroundBrush}"
                                           VerticalAlignment="Center" FontSize="12"/>
                                <TextBlock Text="●" Visibility="{Binding IsModified, Converter={StaticResource BoolToVisibilityConverter}}"
                                           Foreground="{DynamicResource AccentBrush}" FontSize="8"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Button Content="✕" Tag="{Binding}"
                                        Click="TabClose_Click"
                                        Background="Transparent"
                                        Foreground="{DynamicResource TabForegroundBrush}"
                                        FontSize="10" Padding="4,0" Margin="0"
                                        VerticalAlignment="Center" Focusable="False"
                                        BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource EqualityConverter}">
                                        <Binding/>
                                        <Binding Path="DataContext.SelectedTab" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource TabActiveBackgroundBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,2,1,0"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- New Tab Button (inline after tabs) -->
            <Button Grid.Column="2" Command="{Binding NewFileCommand}"
                    Background="Transparent" Foreground="{DynamicResource TabForegroundBrush}"
                    Padding="10,6" Margin="0" VerticalAlignment="Center" Focusable="False"
                    BorderThickness="0" Cursor="Hand" ToolTip="New Tab (Ctrl+N)">
                <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"/>
            </Button>

            <!-- Window Control Buttons (right-aligned) -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Click="MinimizeButton_Click" Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TabForegroundBrush}" Padding="16,8" Cursor="Hand"
                        Focusable="False" ToolTip="Minimize">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"/>
                </Button>
                <Button x:Name="MaxRestoreButton" Click="MaximizeButton_Click" Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TabForegroundBrush}" Padding="16,8" Cursor="Hand"
                        Focusable="False" ToolTip="Maximize">
                    <TextBlock x:Name="MaxRestoreIcon" Text="&#xE922;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"/>
                </Button>
                <Button Click="CloseButton_Click" Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TabForegroundBrush}" Padding="16,8" Cursor="Hand"
                        Focusable="False" ToolTip="Close">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Menu Bar -->
        <Menu Grid.Row="1" Margin="0,0,0,0">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding NewFileCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open..." Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O"/>
                <MenuItem Header="Open _Folder..." Command="{Binding OpenFolderCommand}"/>
                <MenuItem Header="Add F_older to Workspace..." Command="{Binding AddFolderCommand}"/>
                <Separator/>
                <MenuItem Header="Open _Workspace..." Command="{Binding OpenWorkspaceCommand}"/>
                <MenuItem Header="Save Wor_kspace As..." Command="{Binding SaveWorkspaceCommand}"/>
                <Separator/>
                <MenuItem Header="Save Sessio_n As..." Command="{Binding SaveSessionAsCommand}"/>
                <Separator/>
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}" InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="_Print..." Command="{Binding PrintCommand}" InputGestureText="Ctrl+P"/>
                <Separator/>
                <MenuItem Header="_Recent Files" ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                            <Setter Property="Header" Value="{Binding}"/>
                            <Setter Property="Command" Value="{Binding Data.OpenRecentFileAsyncCommand, Source={StaticResource ViewModelProxy}}"/>
                            <Setter Property="CommandParameter" Value="{Binding}"/>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Close Tab" Command="{Binding CloseTabCommand}" InputGestureText="Ctrl+W"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="ApplicationCommands.Undo" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo" Command="ApplicationCommands.Redo" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="_Find..." Command="{Binding FindCommand}" InputGestureText="Ctrl+F"/>
                <MenuItem Header="Find and _Replace..." Command="{Binding ReplaceCommand}" InputGestureText="Ctrl+H"/>
                <MenuItem Header="Find in Fi_les..." Command="{Binding FindInFilesCommand}" InputGestureText="Ctrl+Shift+F"/>
                <MenuItem Header="_Go to Line..." Command="{Binding GoToLineCommand}" InputGestureText="Ctrl+G"/>
                <MenuItem Header="Select _Next Occurrence" Command="{Binding SelectNextOccurrenceCommand}" InputGestureText="Ctrl+D"/>
                <MenuItem Header="Select _All Occurrences" Command="{Binding SelectAllOccurrencesCommand}" InputGestureText="Ctrl+Shift+L"/>
                <Separator/>
                <MenuItem Header="Macros">
                    <MenuItem Header="Start _Recording" Command="{Binding MacroStartRecordingCommand}"/>
                    <MenuItem Header="S_top Recording" Command="{Binding MacroStopRecordingCommand}"/>
                    <MenuItem Header="_Playback" Command="{Binding MacroPlaybackCommand}"/>
                    <MenuItem Header="Playback _Multiple..." Command="{Binding MacroPlaybackMultipleCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Duplicate Line" Command="{Binding DuplicateLineCommand}" InputGestureText="Ctrl+Shift+D"/>
                <MenuItem Header="Move Line _Up" Command="{Binding MoveLineUpCommand}" InputGestureText="Alt+Up"/>
                <MenuItem Header="Move Line Do_wn" Command="{Binding MoveLineDownCommand}" InputGestureText="Alt+Down"/>
                <Separator/>
                <MenuItem Header="_Format Document" Command="{Binding FormatDocumentCommand}" InputGestureText="JSON/XML"/>
                <MenuItem Header="Mi_nify Document" Command="{Binding MinifyDocumentCommand}"/>
                <Separator/>
                <MenuItem Header="_Text Tools">
                    <MenuItem Header="Case">
                        <MenuItem Header="UPPERCASE" Command="{Binding TextToUpperCaseCommand}"/>
                        <MenuItem Header="lowercase" Command="{Binding TextToLowerCaseCommand}"/>
                        <MenuItem Header="Title Case" Command="{Binding TextToTitleCaseCommand}"/>
                        <MenuItem Header="iNVERT cASE" Command="{Binding TextInvertCaseCommand}"/>
                    </MenuItem>
                    <MenuItem Header="Lines">
                        <MenuItem Header="Remove Duplicate Lines" Command="{Binding TextRemoveDuplicateLinesCommand}"/>
                        <MenuItem Header="Sort Lines (A→Z)" Command="{Binding TextSortLinesAscCommand}"/>
                        <MenuItem Header="Sort Lines (Z→A)" Command="{Binding TextSortLinesDescCommand}"/>
                        <MenuItem Header="Trim Trailing Whitespace" Command="{Binding TextTrimTrailingCommand}"/>
                        <MenuItem Header="Trim Leading Whitespace" Command="{Binding TextTrimLeadingCommand}"/>
                        <MenuItem Header="Trim All Whitespace" Command="{Binding TextTrimAllCommand}"/>
                    </MenuItem>
                    <MenuItem Header="Indentation">
                        <MenuItem Header="Tabs → Spaces" Command="{Binding TextTabsToSpacesCommand}"/>
                        <MenuItem Header="Spaces → Tabs" Command="{Binding TextSpacesToTabsCommand}"/>
                    </MenuItem>
                    <MenuItem Header="Encode/Decode">
                        <MenuItem Header="Base64 Encode" Command="{Binding TextBase64EncodeCommand}"/>
                        <MenuItem Header="Base64 Decode" Command="{Binding TextBase64DecodeCommand}"/>
                        <MenuItem Header="URL Encode" Command="{Binding TextUrlEncodeCommand}"/>
                        <MenuItem Header="URL Decode" Command="{Binding TextUrlDecodeCommand}"/>
                    </MenuItem>
                    <MenuItem Header="Checksums">
                        <MenuItem Header="MD5" Command="{Binding TextChecksumMd5Command}"/>
                        <MenuItem Header="SHA-1" Command="{Binding TextChecksumSha1Command}"/>
                        <MenuItem Header="SHA-256" Command="{Binding TextChecksumSha256Command}"/>
                        <MenuItem Header="SHA-512" Command="{Binding TextChecksumSha512Command}"/>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Toggle _Bookmark" Command="{Binding ToggleBookmarkCommand}" InputGestureText="Ctrl+F2"/>
                <MenuItem Header="Next Boo_kmark" Command="{Binding NextBookmarkCommand}" InputGestureText="F2"/>
                <MenuItem Header="Pre_v Bookmark" Command="{Binding PrevBookmarkCommand}" InputGestureText="Shift+F2"/>
                <Separator/>
                <MenuItem Header="Line Endings">
                    <MenuItem Header="Windows (CRLF)" Command="{Binding ConvertLineEndingsCommand}" CommandParameter="CRLF"/>
                    <MenuItem Header="Unix (LF)" Command="{Binding ConvertLineEndingsCommand}" CommandParameter="LF"/>
                    <MenuItem Header="Classic Mac (CR)" Command="{Binding ConvertLineEndingsCommand}" CommandParameter="CR"/>
                </MenuItem>
                <MenuItem Header="Encoding">
                    <MenuItem Header="UTF-8" Command="{Binding ChangeEncodingCommand}" CommandParameter="utf-8"/>
                    <MenuItem Header="UTF-16 LE" Command="{Binding ChangeEncodingCommand}" CommandParameter="utf-16"/>
                    <MenuItem Header="UTF-16 BE" Command="{Binding ChangeEncodingCommand}" CommandParameter="utf-16BE"/>
                    <MenuItem Header="ASCII" Command="{Binding ChangeEncodingCommand}" CommandParameter="us-ascii"/>
                    <MenuItem Header="ISO 8859-1" Command="{Binding ChangeEncodingCommand}" CommandParameter="iso-8859-1"/>
                    <MenuItem Header="Windows 1252" Command="{Binding ChangeEncodingCommand}" CommandParameter="windows-1252"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Word Wrap" IsCheckable="True" IsChecked="{Binding IsWordWrapEnabled, Mode=TwoWay}"/>
                <MenuItem Header="Show _Whitespace" IsCheckable="True" IsChecked="{Binding IsWhitespaceVisible, Mode=TwoWay}"/>
                <MenuItem Header="Code _Folding" IsCheckable="True" IsChecked="{Binding IsFoldingEnabled, Mode=TwoWay}"/>
                <MenuItem Header="_Minimap" IsCheckable="True" IsChecked="{Binding IsMinimapVisible, Mode=TwoWay}"/>
                <MenuItem Header="_Indent Guides" IsCheckable="True" IsChecked="{Binding IsIndentGuidesEnabled, Mode=TwoWay}"/>
                <Separator/>
                <MenuItem Header="Zoom _In" Command="{Binding ZoomInCommand}" InputGestureText="Ctrl++"/>
                <MenuItem Header="Zoom _Out" Command="{Binding ZoomOutCommand}" InputGestureText="Ctrl+-"/>
                <MenuItem Header="_Reset Zoom" Command="{Binding ResetZoomCommand}" InputGestureText="Ctrl+0"/>
                <Separator/>
                <MenuItem Header="Split _Editor" Command="{Binding ToggleSplitViewCommand}" InputGestureText="Ctrl+\"/>
                <MenuItem Header="_Terminal" Command="{Binding ToggleCommandRunnerCommand}" InputGestureText="Ctrl+`"/>
                <Separator/>
                <MenuItem Header="_Auto-Reload (Tail)" IsCheckable="True" IsChecked="{Binding IsAutoReloadEnabled, Mode=TwoWay}"/>
                <MenuItem Header="Compare _Files..." Command="{Binding CompareFilesCommand}"/>
                <MenuItem Header="Command _Palette" Command="{Binding CommandPaletteCommand}" InputGestureText="Ctrl+Shift+P"/>
                <Separator/>
                <MenuItem Header="_Theme" ItemsSource="{Binding AvailableThemes}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                            <Setter Property="Header" Value="{Binding DisplayName}"/>
                            <Setter Property="Command" Value="{Binding Data.ChangeThemeCommand, Source={StaticResource ViewModelProxy}}"/>
                            <Setter Property="CommandParameter" Value="{Binding Name}"/>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Refresh Themes" Command="{Binding RefreshThemesCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" MaxWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- File Tree Panel -->
            <Border Grid.Column="0" Background="{DynamicResource PanelBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,8">
                        <TextBlock Text="EXPLORER"
                                   Foreground="{DynamicResource WindowForegroundBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TreeView Grid.Row="1"
                              x:Name="FileTreeView"
                              ItemsSource="{Binding FileTree.RootNodes}"
                              BorderThickness="0"
                              Background="{DynamicResource TreeViewBackgroundBrush}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              MouseDoubleClick="FileTreeView_MouseDoubleClick">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{DynamicResource WindowForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource PanelBorderBrush}"/>

            <!-- Editor Area -->
            <Grid Grid.Column="2">
                <!-- Editor Content (tabs are in title bar) -->
                <ContentControl Content="{Binding SelectedTab}"
                                Visibility="{Binding SelectedTab, Converter={StaticResource NullToCollapsedConverter}}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <controls:EditorHost DataContext="{Binding}"/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

                <!-- Empty State -->
                <Border Background="{DynamicResource EditorBackgroundBrush}"
                        Visibility="{Binding Tabs.Count, Converter={StaticResource CountToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="FastEdit"
                                   FontSize="32"
                                   FontWeight="Light"
                                   Foreground="{DynamicResource WindowForegroundBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Open a file or folder to get started"
                                   FontSize="14"
                                   Foreground="{DynamicResource TabForegroundBrush}"
                                   Margin="0,8,0,20"
                                   HorizontalAlignment="Center"/>
                        <ui:Button Content="Open File"
                                   Appearance="Primary"
                                   Command="{Binding OpenFileCommand}"
                                   Padding="16,8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Find In Files Panel -->
            <controls:FindInFilesPanel x:Name="FindInFilesPanel"
                                       Grid.Row="1" Grid.ColumnSpan="3"
                                       Height="250"
                                       Visibility="Collapsed"/>
        </Grid>

        <!-- Terminal Splitter -->
        <GridSplitter Grid.Row="3" Height="4" HorizontalAlignment="Stretch"
                      Background="{DynamicResource PanelBorderBrush}"
                      Cursor="SizeNS"
                      Visibility="{Binding IsCommandRunnerVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <!-- Command Runner Panel -->
        <controls:CommandRunnerPanel x:Name="CommandRunner"
                                      Grid.Row="4"
                                      MinHeight="100" Height="250"
                                      Visibility="{Binding IsCommandRunnerVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <!-- Status Bar -->
        <StatusBar Grid.Row="5" Style="{StaticResource EditorStatusBarStyle}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource StatusBarForegroundBrush}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding GitBranch}" Foreground="{DynamicResource AccentBrush}" Margin="0,0,16,0"
                               FontSize="11" VerticalAlignment="Center"
                               Visibility="{Binding GitBranch, Converter={StaticResource NullToCollapsedConverter}}"
                               ToolTip="Git branch"/>
                    <TextBlock Text="{Binding SelectedTab.SyntaxLanguage}" Foreground="{DynamicResource StatusBarForegroundBrush}" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding LineEnding}" Foreground="{DynamicResource StatusBarForegroundBrush}" Margin="0,0,16,0"
                               ToolTip="Line ending type"/>
                    <TextBlock Text="{Binding SelectedTab.Encoding}" Foreground="{DynamicResource StatusBarForegroundBrush}" Margin="0,0,16,0"/>
                    <Button Content="{Binding SelectedTab.IsBinaryMode, Converter={StaticResource BoolToModeConverter}}"
                            Command="{Binding SelectedTab.ToggleModeAsyncCommand}"
                            Foreground="{DynamicResource StatusBarForegroundBrush}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="6,0"
                            Margin="0,0,16,0"
                            FontSize="12"
                            ToolTip="Toggle between Text and Hex mode"
                            Cursor="Hand"
                            Visibility="{Binding SelectedTab, Converter={StaticResource NullToCollapsedConverter}}"/>
                    <TextBlock Text="{Binding CurrentThemeName}" Foreground="{DynamicResource StatusBarForegroundBrush}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</ui:FluentWindow>
