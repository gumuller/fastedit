<Window x:Class="FastEdit.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:FastEdit.Views.Controls"
        xmlns:vm="clr-namespace:FastEdit.ViewModels"
        mc:Ignorable="d"
        Title="FastEdit"
        Height="700"
        Width="1100"
        MinHeight="400"
        MinWidth="600"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False">

    <!-- Custom Window Chrome for resize/move behavior -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewFileCommand}"/>
        <KeyBinding Key="W" Modifiers="Control" Command="{Binding CloseTabCommand}"/>
    </Window.InputBindings>

    <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="{DynamicResource TitleBarBackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Icon and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="■"
                               FontSize="14"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="FastEdit"
                               Foreground="{DynamicResource TitleBarForegroundBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Window Control Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton"
                            Click="MinimizeButton_Click"
                            Style="{StaticResource WindowControlButtonStyle}">
                        <Path Data="M 0 0 H 10" Stroke="{DynamicResource TitleBarForegroundBrush}" StrokeThickness="1" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Click="MaximizeButton_Click"
                            Style="{StaticResource WindowControlButtonStyle}">
                        <Path Data="M 0 0 H 10 V 10 H 0 Z" Stroke="{DynamicResource TitleBarForegroundBrush}" StrokeThickness="1" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="CloseButton"
                            Click="CloseButton_Click"
                            Style="{StaticResource WindowCloseButtonStyle}">
                        <Path Data="M 0 0 L 10 10 M 10 0 L 0 10" Stroke="{DynamicResource TitleBarForegroundBrush}" StrokeThickness="1" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Menu Bar -->
            <Menu Grid.Row="1" Background="{DynamicResource TitleBarBackgroundBrush}">
                <MenuItem Header="_File">
                    <MenuItem Header="_New" Command="{Binding NewFileCommand}" InputGestureText="Ctrl+N"/>
                    <MenuItem Header="_Open..." Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O"/>
                    <MenuItem Header="Open _Folder..." Command="{Binding OpenFolderCommand}"/>
                    <Separator/>
                    <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S"/>
                    <Separator/>
                    <MenuItem Header="_Close Tab" Command="{Binding CloseTabCommand}" InputGestureText="Ctrl+W"/>
                    <Separator/>
                    <MenuItem Header="E_xit" Click="Exit_Click"/>
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="_Theme" ItemsSource="{Binding AvailableThemes}">
                        <MenuItem.ItemContainerStyle>
                            <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                <Setter Property="Header" Value="{Binding DisplayName}"/>
                                <Setter Property="Command" Value="{Binding DataContext.ChangeThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <Setter Property="CommandParameter" Value="{Binding Name}"/>
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="_Help">
                    <MenuItem Header="_About" Click="About_Click"/>
                </MenuItem>
            </Menu>

            <!-- Main Content -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" MinWidth="150" MaxWidth="400"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- File Tree Panel -->
                <Border Grid.Column="0" Background="{DynamicResource PanelBackgroundBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
                            <TextBlock Text="EXPLORER"
                                       Foreground="{DynamicResource WindowForegroundBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TreeView Grid.Row="1"
                                  x:Name="FileTreeView"
                                  ItemsSource="{Binding FileTree.RootNodes}"
                                  BorderThickness="0"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  MouseDoubleClick="FileTreeView_MouseDoubleClick">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="2">
                                        <TextBlock Text="{Binding Icon}" Margin="0,0,4,0" FontFamily="Segoe UI Symbol"/>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource WindowForegroundBrush}"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource WindowForegroundBrush}"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </Grid>
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1"
                              Width="4"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="{DynamicResource PanelBorderBrush}"/>

                <!-- Editor Area -->
                <Grid Grid.Column="2">
                    <!-- Tabs and Editor -->
                    <TabControl ItemsSource="{Binding Tabs}"
                                SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                                Background="{DynamicResource EditorBackgroundBrush}"
                                BorderThickness="0"
                                IsSynchronizedWithCurrentItem="True">
                        <TabControl.ItemContainerStyle>
                            <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                                <Setter Property="Header" Value="{Binding}"/>
                            </Style>
                        </TabControl.ItemContainerStyle>
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding FileName}" Margin="0,0,8,0"/>
                                    <TextBlock Text="*" Visibility="{Binding IsModified, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <Button Content="✕"
                                            Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            Foreground="{DynamicResource TabForegroundBrush}"
                                            FontSize="10"
                                            Padding="4,0"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            Focusable="False"/>
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <controls:EditorHost DataContext="{Binding}"/>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <!-- Empty State -->
                    <Border Background="{DynamicResource EditorBackgroundBrush}"
                            Visibility="{Binding Tabs.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="FastEdit"
                                       FontSize="32"
                                       FontWeight="Light"
                                       Foreground="{DynamicResource WindowForegroundBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Open a file or folder to get started"
                                       FontSize="14"
                                       Foreground="{DynamicResource TabForegroundBrush}"
                                       Margin="0,8,0,20"
                                       HorizontalAlignment="Center"/>
                            <Button Content="Open File"
                                    Command="{Binding OpenFileCommand}"
                                    Padding="16,8"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Status Bar -->
            <StatusBar Grid.Row="3">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusText}"/>
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding SelectedTab.SyntaxLanguage}" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding SelectedTab.Encoding}" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding CurrentThemeName}"/>
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Border>
</Window>
